# Copy this file to .env and fill in real values. Never commit .env.

# This API's own listen port.
PORT=4000

# Must match wherever the NuroDial frontend is served from.
CORS_ORIGIN=http://localhost:5183

# VICIDial's MySQL database. Use a SELECT-only account for this phase —
# this API only reads data, it never writes.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=nurodial_readonly
DB_PASS=changeme
DB_NAME=asterisk
