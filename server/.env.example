# Copy this file to .env and fill in real values. Never commit .env.

# This API's own listen port.
PORT=4000

# Comma-separated list of every origin the frontend is served from
# (supports running the dev server and the HTTPS reverse proxy at once
# during a gradual cutover).
CORS_ORIGIN=http://localhost:5173,https://192.168.100.40:8443

# VICIDial's MySQL database — read pool. SELECT-only account.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=nurodial_readonly
DB_PASS=changeme
DB_NAME=asterisk

# Separate write pool — narrowly column/table-scoped grants only
# (see project memory for the exact grant list). Never point this at
# nurodial_readonly or a root-equivalent account.
DB_AGENT_USER=nurodial_agent
DB_AGENT_PASS=changeme

# Signs/verifies this API's own JWTs. Any long random string; rotating it
# invalidates all existing sessions.
JWT_SECRET=changeme
JWT_EXPIRES_IN=8h

# Asterisk Manager Interface — real call control (Originate/Hangup/ChanSpy).
# Must match a [username] stanza in /etc/asterisk/manager.conf on the VICIDial
# box. Never hardcode these as source-code fallbacks (see project memory —
# this project's own history briefly did exactly that).
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USERNAME=changeme
AMI_SECRET=changeme
